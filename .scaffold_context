export async function extractFromInput<T = Record<string, unknown>>(
  schemaDescription: string,
  options: {
    dataUri?: string;
    userText?: string;
    photoContext?: string;
    intent?: string;
  } = {}
): Promise<T> {
  const { dataUri, userText, photoContext, intent } = options;
  const hasMedia = !!dataUri;
  const hasText = !!userText?.trim();
  if (!hasMedia && !hasText) {
